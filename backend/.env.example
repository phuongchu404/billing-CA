# MySQL (cài ngoài host — điền đúng port, user, password)
MYSQL_PORT=3307
DB_USERNAME=root
DB_PASSWORD=123456

# SSO (Keycloak hoặc service ngoài)
SSO_JWKS_URI=http://host.docker.internal:9090/.well-known/jwks.json

# Frontend URL (dùng trong email)
APP_FRONTEND_URL=http://localhost

# RS Core
RS_CORE_BASE_URL=http://host.docker.internal:8081
RS_CORE_SERVICE_TOKEN=dev-service-token

# Webhook
WEBHOOK_SECRET=dev-webhook-secret-change-in-prod

# Mail
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=phuongchu404@gmail.com
MAIL_PASSWORD=
MAIL_FROM_NAME=Subscription Management
MAIL_FROM_ADDRESS=phuongchu404@gmail.com
